/*
  睡眠报告页面样式 — 柔和蓝白色调医疗健康风格
  24rpx 大圆角白色卡片、细微阴影、清晰层级
  主文本 #1a3a6b / 辅助 #5b7094 / 提示 #8da4c1
*/

/* ========== 全局基础 ========== */
page {
  height: 100vh;
  overflow-y: auto;
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 通用卡片 — 白底、24rpx 大圆角、细微阴影 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* 页面主容器 — 内边距 24rpx */
.report-container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

/* ========== 日期选择器 ========== */
.date-picker-row {
  margin-bottom: 24rpx;
}

.date-display {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.date-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a3a6b;
  margin-right: 12rpx;
  letter-spacing: 1rpx;
}

.date-arrow {
  font-size: 22rpx;
  color: #8da4c1;
}

/* ========== 睡眠评分大卡片 ========== */
.score-card {
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
  background: linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
  border: 1rpx solid rgba(122, 160, 255, 0.15);
}

.score-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.score-label {
  font-size: 30rpx;
  color: #5b7094;
  font-weight: 500;
}

.score-grade {
  font-size: 26rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #7aa0ff 0%, #5b8def 100%);
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

/* 大圆形评分 — conic-gradient 圆环 + 内层白色圆盘 */
.score-circle {
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: conic-gradient(#7aa0ff 0%, #a7c3ff 50%, #e8f0ff 50%, #e8f0ff 100%);
  box-shadow: 0 8rpx 30rpx rgba(122, 160, 255, 0.2);
  position: relative;
}

/* 伪元素覆盖内层白色圆盘 */
.score-circle::after {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: #ffffff;
  border-radius: 50%;
}

/* 居中大号数字 — 80rpx */
.score-value {
  position: relative;
  z-index: 1;
  font-size: 80rpx;
  font-weight: 700;
  color: #1a3a6b;
  line-height: 1;
}

/* 单位小字 */
.score-unit {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  color: #8da4c1;
  margin-left: 6rpx;
  margin-top: 30rpx;
}

/* 底部灰色提示文字 */
.score-tips {
  font-size: 26rpx;
  color: #7a8ba8;
  line-height: 1.6;
}

/* ========== 关键指标摘要四宫格 ========== */
.summary-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.summary-item {
  width: calc(50% - 12rpx);
  padding: 28rpx 0;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.summary-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a3a6b;
  margin-bottom: 6rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #8da4c1;
}

/* ========== 卡片区域通用 ========== */
.section-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a3a6b;
  display: block;
}

.section-subtitle {
  font-size: 24rpx;
  color: #8da4c1;
  margin-top: 8rpx;
  display: block;
}

/* ========== 加载 / 错误提示 ========== */
.loading-box,
.error-box {
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafbfc;
  border-radius: 16rpx;
}

.loading-text,
.error-text {
  font-size: 28rpx;
  color: #8da4c1;
}

/* ========== 图表容器 ========== */
.chart-wrapper {
  height: 520rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fafbfc;
}

.chart-wrapper ec-canvas {
  width: 100%;
  height: 100%;
}

/* ========== 噪音图表容器 ========== */

/* 噪音图表与上方分期图表间距 16px */
.noise-section {
  margin-top: 32rpx;             /* ≈16px */
}

/* 噪音图表标题 — 16px 加粗 #1a2c3e */
.noise-title {
  font-size: 32rpx;              /* ≈16px */
  font-weight: 700;
  color: #1a2c3e;
  display: block;
  margin-bottom: 16rpx;          /* ≈8px 下边距 */
}

/* 噪音图表容器 — 左右12px 上下8px 白色 圆角8px 阴影 */
.noise-chart-wrapper {
  margin: 16rpx 24rpx;           /* ≈8px 上下, ≈12px 左右 */
  padding: 16rpx 0;              /* 内边距 */
  height: 500rpx;                /* ≈250px */
  background: #ffffff;
  border-radius: 16rpx;          /* ≈8px */
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.noise-chart-wrapper ec-canvas {
  width: 100%;
  height: 100%;
}

/* ========== 底部图例 ========== */
.legend-row {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-right: 32rpx;
  margin-bottom: 12rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.legend-text {
  font-size: 24rpx;
  color: #5b7094;
}

/* ========== 睡眠结构进度条 ========== */
.stage-bars {
  padding-top: 8rpx;
}

.stage-bar-item {
  margin-bottom: 28rpx;
}

.stage-bar-item:last-child {
  margin-bottom: 0;
}

.stage-bar-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.stage-name {
  font-size: 28rpx;
  color: #5b7094;
  font-weight: 500;
}

.stage-time {
  font-size: 26rpx;
  color: #8da4c1;
}

/* 灰色底条 */
.stage-bar-bg {
  height: 18rpx;
  background: #eef1f6;
  border-radius: 12rpx;
  overflow: hidden;
}

/* 彩色渐变填充条 — 带 transition 动画 */
.stage-bar-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.6s ease;
}

/* 深睡 #7aa0ff → #5b8def */
.stage-bar-fill.deep {
  background: linear-gradient(90deg, #7aa0ff 0%, #5b8def 100%);
}

/* 浅睡 #a7c3ff → #8daeff */
.stage-bar-fill.light {
  background: linear-gradient(90deg, #a7c3ff 0%, #8daeff 100%);
}

/* REM #ffd6a7 → #ffbb7a */
.stage-bar-fill.rem {
  background: linear-gradient(90deg, #ffd6a7 0%, #ffbb7a 100%);
}

/* 清醒 #ff9f9f → #ff7a7a */
.stage-bar-fill.wake {
  background: linear-gradient(90deg, #ff9f9f 0%, #ff7a7a 100%);
}

/* ========== 异常事件列表 ========== */
.event-list {
  padding-top: 8rpx;
}

.event-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.event-item:last-child {
  border-bottom: none;
}

.event-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  margin-top: 2rpx;
}

.event-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.event-type {
  font-size: 28rpx;
  color: #1a3a6b;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.event-time {
  font-size: 24rpx;
  color: #8da4c1;
}
