<!--
  作息设置页面模板
  包含就寝时间、起床时间、日出模拟时长三项设置
  数据由 settings.js 调用 GET /api/settings 接口获取
-->
<view class="settings-container">

  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">作息设置</text>
  </view>

  <!-- 加载中状态 -->
  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 设置表单 -->
  <view class="settings-form" wx:else>

    <!-- 就寝时间 — mode="time" -->
    <view class="setting-card card">
      <view class="setting-row">
        <text class="setting-label">就寝时间</text>
        <picker
          mode="time"
          value="{{bedTime}}"
          bindchange="onBedTimeChange"
        >
          <view class="picker-display">
            <text class="picker-value">{{bedTime}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 起床时间 — mode="time" -->
    <view class="setting-card card">
      <view class="setting-row">
        <text class="setting-label">起床时间</text>
        <picker
          mode="time"
          value="{{wakeTime}}"
          bindchange="onWakeTimeChange"
        >
          <view class="picker-display">
            <text class="picker-value">{{wakeTime}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 日出模拟时长 — slider 5-30 分钟 -->
    <view class="setting-card card">
      <view class="setting-row">
        <text class="setting-label">日出模拟时长</text>
        <text class="slider-value">{{sunriseDuration}} 分钟</text>
      </view>
      <view class="slider-row">
        <text class="slider-min">5</text>
        <slider
          min="5"
          max="30"
          step="1"
          value="{{sunriseDuration}}"
          bindchange="onSunriseChange"
          activeColor="#4A90D9"
          backgroundColor="#eef1f6"
          block-size="20"
        />
        <text class="slider-max">30</text>
      </view>
    </view>

    <!-- 保存按钮 -->
    <view class="save-action">
      <button bindtap="saveSettings">保存</button>
    </view>

  </view>

</view>
